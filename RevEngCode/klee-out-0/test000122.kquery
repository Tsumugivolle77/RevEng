array num[4] : w32 -> w8 = symbolic
(query [(Eq false
             (Eq 0
                 (And w32 (AShr w32 N0:(ReadLSB w32 0 num)
                                    0)
                          1)))
         (Eq false
             (Eq 0
                 (And w32 (AShr w32 N0 1) 1)))
         (Eq 0
             (And w32 (AShr w32 N0 2) 1))
         (Eq false
             (Eq 0
                 (And w32 (AShr w32 N0 3) 1)))
         (Eq 0
             (And w32 (AShr w32 N0 4) 1))
         (Eq false
             (Eq 0
                 (And w32 (AShr w32 N0 5) 1)))
         (Eq 0
             (And w32 (AShr w32 N0 6) 1))
         (Eq false
             (Eq 0
                 (And w32 (AShr w32 N0 7) 1)))
         (Eq false
             (Eq 0
                 (And w32 (AShr w32 N0 8) 1)))
         (Eq false
             (Eq 0
                 (And w32 (AShr w32 N0 9) 1)))]
        false)
